generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
  AUDITOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role, isActive])
}

model MissingPersonBulletin {
  id               String   @id @default(cuid())
  publicCode       String   @unique
  displayName      String
  age              Int
  lastSeenDate     DateTime
  lastSeenLocation String
  summary          String   @db.Text
  imageUrl         String?
  status           ContentStatus @default(DRAFT)
  encryptedNotes   String?  @db.Text
  isFictional      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, createdAt])
}

model PressRelease {
  id          String        @id @default(cuid())
  title       String
  publishedAt DateTime
  excerpt     String        @db.Text
  imageUrl    String
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
}

model RewardBulletin {
  id          String        @id @default(cuid())
  title       String
  rewardText  String
  phone       String
  imageUrl    String?
  status      ContentStatus @default(DRAFT)
  isFictional Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model WantedPerson {
  id          String        @id @default(cuid())
  displayName String
  alias       String?
  rewardText  String
  caseCode    String        @unique
  imageUrl    String?
  statusLabel String        @default("Se busca")
  status      ContentStatus @default(DRAFT)
  isFictional Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  ipHash    String
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
}
